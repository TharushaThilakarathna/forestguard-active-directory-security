    <system.webServer>
        <handlers>
            <add name="ForestGuardHandler" path="*" verb="*" modules="FastCgiModule" scriptProcessor="C:\inetpub\wwwroot\forestguard\venv\Scripts\python.exe|C:\inetpub\wwwroot\forestguard\venv\Lib\site-packages\wfastcgi.py" resourceType="Unspecified" />
